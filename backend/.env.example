# Firebase Admin SDK (server-side secrets)
FIREBASE_PROJECT_ID=
FIREBASE_PRIVATE_KEY_ID=
FIREBASE_PRIVATE_KEY=
FIREBASE_CLIENT_EMAIL=
FIREBASE_CLIENT_ID=

# CORS — comma-separated list of allowed frontend origins
# e.g. https://yourapp.com,https://www.yourapp.com
ALLOWED_ORIGINS=http://localhost:3000

# Primary frontend URL (used by CORS defaults and AI insights fallback URL)
FRONTEND_URL=http://localhost:3000

# Optional explicit comma-separated AI insights endpoints
# e.g. https://your-frontend.com/api/ai-insights
FRONTEND_API_URLS=
